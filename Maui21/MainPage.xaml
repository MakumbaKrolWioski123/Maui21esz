<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui21.MainPage">

    <ScrollView>
        <VerticalStackLayout
         Padding="30,0"
         Spacing="25"
         WidthRequest="400">
            <Image
             Source="dotnet_bot.png"
             HeightRequest="185"
             Aspect="AspectFit"
             SemanticProperties.Description="dot net bot in a submarine number ten" />

            <Label
             Text="Zaloguj się!"
             Style="{StaticResource Headline}"
             SemanticProperties.HeadingLevel="Level1" />

            <Entry
             x:Name="EmailEntry"
             Placeholder="Email"
             Keyboard="Email"
             TextChanged="Zmiana"/>
            <Entry
             x:Name="PasswordEntry"
             Placeholder="Password"
             IsPassword="True"
             TextChanged="Zmiana"/>

            <Button
             x:Name="ZalogujButton"
             Text="Zaloguj" 
             Clicked="Login"
             HorizontalOptions="Fill"
             IsVisible="False"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
